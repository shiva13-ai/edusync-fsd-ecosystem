# edusync-node-backend/.env

PORT=5000
MONGO_URI=mongodb://localhost:27017/edusync

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=edusync_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=7d

# ── AI (Google Gemini) ───────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AQ.Abxxxxxxxxxxxxxxxxxxxxx"xxx

# Gemini model to use — gemini-1.5-flash is fast & free tier friendly
# Other options: gemini-1.5-pro, gemini-2.0-flash-exp
GEMINI_MODEL=gemini-1.5-flash

# ── Internal service URLs ────────────────────────────────────────────────────
SPRING_BOOT_API=http://localhost:8090
